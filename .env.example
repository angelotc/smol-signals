# Hugging Face token (required for Dataset writes and HF fallback inference)
HF_TOKEN=""

# Optional: use the fine-tuned Gemma 4 12B Modal + SGLang endpoint for model calls.
MODAL_GEMMA4_URL="https://angelotc--smol-signals-gemma4-sglang-merged-repair-serve.modal.run"
MODAL_GEMMA4_MODEL="small-signals-gemma-4-12b-signals"
# MODAL_GEMMA4_TIMEOUT="1200"

# Optional: override the small model (must be <=32B params for the hackathon).
# Used only when MODAL_GEMMA4_URL is unset. Must be served by an HF Inference
# provider on your account.
HF_MODEL="google/gemma-3-27b-it"

# Optional: full channel history + search-by-name. Without it the app uses the
# public RSS feed (most recent uploads only).
YOUTUBE_API_KEY=""

# Required for YouTube analysis: public page/feed and transcript fetches use
# Zyte extract API. This does not replace YOUTUBE_API_KEY for full history/search.
ZYTE_API_KEY=""
# ZYTE_API_TIMEOUT="45"

# Optional: retry transient transcript fetch failures. Permanent states such as
# unavailable videos, disabled transcripts, and missing languages are not retried.
# TRANSCRIPT_FETCH_RETRIES="2"
# TRANSCRIPT_FETCH_RETRY_BACKOFF="1.5"

# Optional: preferred transcript language
YOUTUBE_TRANSCRIPT_LANG="en"

# Optional: how many videos to analyze concurrently (default 6). Each video is
# mostly network wait (transcript + LLM + Yahoo), so higher = faster — but lower
# this if the HF Inference router starts rate-limiting (HTTP 429) your model.
# ANALYZE_CONCURRENCY="6"
